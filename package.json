{
  "name": "esti",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@8.15.5",
  "scripts": {
    "dev": "vite",
    "dev:arc": "BROWSER='Arc' vite --open",
    "db": "firebase emulators:start --import=./database --only firestore",
    "esti": "pnpm db & pnpm dev:arc",
    "lint": "eslint .",
    "types": "vue-tsc --noEmit",
    "build": "vite build",
    "generate": "vite-ssg build",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:prod": "MY_BASE_URL=https://esti.patbird.me/ pnpm exec playwright test"
  },
  "dependencies": {
    "@headlessui/vue": "1.7.19",
    "@vueuse/core": "10.9.0",
    "@vueuse/head": "2.0.0",
    "firebase": "10.10.0",
    "floating-vue": "5.2.2",
    "pinia": "2.1.7",
    "vue": "3.4.21",
    "vue-router": "4.3.0",
    "vuefire": "3.1.23"
  },
  "devDependencies": {
    "@antfu/eslint-config": "2.11.4",
    "@iconify/json": "2.2.196",
    "@playwright/test": "1.42.1",
    "@types/node": "20.11.30",
    "@unocss/eslint-config": "0.58.8",
    "@unocss/preset-attributify": "0.58.8",
    "@unocss/preset-icons": "0.58.8",
    "@unocss/reset": "0.58.8",
    "@unocss/transformer-variant-group": "0.58.8",
    "@vitejs/plugin-vue": "5.0.4",
    "critters": "0.0.22",
    "eslint": "8.57.0",
    "eslint-plugin-vue": "9.24.0",
    "firebase-admin": "12.0.0",
    "happy-dom": "13.10.1",
    "typescript": "5.4.3",
    "unocss": "0.58.8",
    "unplugin-auto-import": "0.17.5",
    "unplugin-icons": "0.18.5",
    "unplugin-vue-components": "0.26.0",
    "vite": "5.2.6",
    "vite-plugin-pages": "0.32.1",
    "vite-plugin-vue-devtools": "7.0.25",
    "vite-plugin-vue-layouts": "0.11.0",
    "vite-ssg": "0.23.6",
    "vitest": "1.4.0",
    "vue-tsc": "1.8.27"
  }
}
